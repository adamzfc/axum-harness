# ── Google OAuth ────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Backend API ─────────────────────────────────────────────
API_URL=http://localhost:3010

# ── Logging ─────────────────────────────────────────────────
# Levels: error, warn, info, debug, trace
# Format: <default_level>,<crate>=<level>,...
RUST_LOG=info,native_tauri=debug

# ── Build Cache (sccache) ──────────────────────────────────
# Install: scoop install sccache (Windows) or cargo install sccache --locked
# Cache location: defaults to ~/.cache/sccache or set custom path below
# SCCACHE_DIR=./.sccache
# RUSTC_WRAPPER=sccache

# ── Build Output Directory ─────────────────────────────────
# Redirect build output to save C disk space (e.g. D:/dev-storage/cache/...)
# CARGO_TARGET_DIR=D:/dev-storage/cache/cargo-target/tauri-sveltekit-axum-moon-template

# ── Cache Locations Reference ──────────────────────────────
# CARGO_HOME (registry, git db):  D:\dev-storage\scoop\persist\rustup\.cargo
# RUSTUP_HOME (toolchains):       D:\dev-storage\scoop\persist\rustup\.rustup
# Project target (build output):  set CARGO_TARGET_DIR above or leave default

# ── Web BFF Server (figment, WEB_BFF_ prefix) ───────────────
# These are read by servers/bff/web-bff via figment Env::prefixed("WEB_BFF_")
# Matching config struct: servers/bff/web-bff/src/config.rs
WEB_BFF_SERVER_HOST=0.0.0.0
WEB_BFF_SERVER_PORT=3010
WEB_BFF_SERVER_REQUEST_TIMEOUT_SECS=30

WEB_BFF_DATABASE_URL=file:.data/web-bff.db

WEB_BFF_CACHE_MAX_CAPACITY=10000
WEB_BFF_CACHE_TTL_SECS=300

WEB_BFF_AUTH_JWT_SECRET=dev-secret-change-in-production
WEB_BFF_AUTH_JWT_EXPIRATION_SECS=86400

# ── Admin BFF Server (figment, ADMIN_BFF_ prefix) ───────────
# These are read by servers/bff/admin-bff via figment Env::prefixed("ADMIN_BFF_")
# Matching config struct: servers/bff/admin-bff/src/config.rs
ADMIN_BFF_SERVER_HOST=0.0.0.0
ADMIN_BFF_SERVER_PORT=3020
ADMIN_BFF_SERVER_REQUEST_TIMEOUT_SECS=30

ADMIN_BFF_DATABASE_URL=file:.data/admin-bff.db

ADMIN_BFF_CACHE_MAX_CAPACITY=10000
ADMIN_BFF_CACHE_TTL_SECS=300

ADMIN_BFF_AUTH_JWT_SECRET=dev-secret-change-in-production
ADMIN_BFF_AUTH_JWT_EXPIRATION_SECS=86400
