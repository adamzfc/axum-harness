{
  "info": {
    "name": "Runtime Server API E2E",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "jwtToken", "value": "" },
    { "key": "tenantId", "value": "" }
  ],
  "item": [
    {
      "name": "Health & Readiness",
      "item": [
        {
          "name": "GET /healthz",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/healthz", "host": ["{{baseUrl}}"], "path": ["healthz"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('response has ok status', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /readyz",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/readyz", "host": ["{{baseUrl}}"], "path": ["readyz"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('response has ready status', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('ready');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Tenant Lifecycle",
      "item": [
        {
          "name": "POST /api/tenant/init — create new tenant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"user_sub\": \"e2e-test-user\", \"user_name\": \"E2E Test\" }"
            },
            "url": { "raw": "{{baseUrl}}/api/tenant/init", "host": ["{{baseUrl}}"], "path": ["api", "tenant", "init"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('response has tenant_id', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('tenant_id');",
                  "  pm.expect(body.role).to.eql('owner');",
                  "  // created may be true (new) or false (existing) — both valid",
                  "  pm.collectionVariables.set('tenantId', body.tenant_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /api/tenant/init — idempotent (same token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"user_sub\": \"e2e-test-user\", \"user_name\": \"E2E Test\" }"
            },
            "url": { "raw": "{{baseUrl}}/api/tenant/init", "host": ["{{baseUrl}}"], "path": ["api", "tenant", "init"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('returns existing tenant (created=false)', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.created).to.eql(false);",
                  "  pm.expect(body.tenant_id).to.eql(pm.collectionVariables.get('tenantId'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /api/tenant/init — reject empty user_sub",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"user_sub\": \"\", \"user_name\": \"E2E Test\" }"
            },
            "url": { "raw": "{{baseUrl}}/api/tenant/init", "host": ["{{baseUrl}}"], "path": ["api", "tenant", "init"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 422 (validation error)', () => {",
                  "  pm.response.to.have.status(422);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /api/tenant/init — without auth returns 401",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"user_sub\": \"no-auth-user\", \"user_name\": \"No Auth\" }"
            },
            "url": { "raw": "{{baseUrl}}/api/tenant/init", "host": ["{{baseUrl}}"], "path": ["api", "tenant", "init"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 401 without auth', () => {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
