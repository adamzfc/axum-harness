{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Service",
  "description": "A service is a business capability and state boundary library. Its fine-grained distributed semantics live in services/<name>/model.yaml.",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "platform/v1"
    },
    "kind": {
      "type": "string",
      "const": "ServiceSemantics"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": [
        "owns_entities",
        "accepted_commands",
        "published_events",
        "served_queries",
        "cross_service_reads",
        "spec_completeness"
      ],
      "properties": {
        "owns_entities": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/entity" }
        },
        "accepted_commands": {
          "type": "array",
          "items": { "$ref": "#/definitions/command" }
        },
        "published_events": {
          "type": "array",
          "items": { "$ref": "#/definitions/event" }
        },
        "served_queries": {
          "type": "array",
          "items": { "$ref": "#/definitions/query" }
        },
        "cross_service_reads": {
          "type": "array",
          "items": { "$ref": "#/definitions/cross_service_read" }
        },
        "authz": {
          "type": "object",
          "properties": {
            "required": { "type": "boolean" },
            "model": { "type": "string" },
            "consistency_hint": {
              "type": "string",
              "enum": ["MINIMIZE_LATENCY", "HIGHER_CONSISTENCY"]
            }
          },
          "additionalProperties": false
        },
        "spec_completeness": {
          "$ref": "#/definitions/spec_completeness"
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "entity": {
      "type": "object",
      "required": [
        "name",
        "aggregate_root",
        "authoritative_store",
        "write_authority",
        "partition_key",
        "delete_semantics"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "aggregate_root": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "authoritative_store": {
          "type": "string"
        },
        "write_authority": {
          "type": "string",
          "enum": ["single-writer", "partitioned-single-writer", "lease-writer"]
        },
        "versioning": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["cas", "monotonic-version", "sequence", "custom"]
            },
            "field": { "type": "string" }
          },
          "additionalProperties": false
        },
        "partition_key": {
          "type": "string"
        },
        "delete_semantics": {
          "type": "string",
          "enum": ["soft", "hard", "tombstone"]
        },
        "rebuild_source": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "command": {
      "type": "object",
      "required": ["name", "idempotency_key"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "idempotency_key": {
          "type": "string"
        },
        "timeout": {
          "type": "string"
        },
        "consistency_requirement": {
          "type": "string",
          "enum": ["strong", "read-your-write", "monotonic-read", "bounded-staleness", "eventual"]
        },
        "compensation": {
          "type": "string"
        },
        "audit": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "event": {
      "type": "object",
      "required": ["name", "ordering_scope", "replayable"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "ordering_scope": {
          "type": "string",
          "enum": ["global", "per-tenant", "per-entity", "none"]
        },
        "dedupe_rule": {
          "type": "string"
        },
        "replayable": {
          "type": "boolean"
        },
        "schema_version": {
          "type": "string"
        },
        "retention": {
          "type": "string"
        },
        "compatibility_policy": {
          "type": "string",
          "enum": ["backward", "forward", "full", "none"]
        }
      },
      "additionalProperties": false
    },
    "query": {
      "type": "object",
      "required": ["name", "consistency_level"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "consistency_level": {
          "type": "string",
          "enum": ["strong", "read-your-write", "monotonic-read", "bounded-staleness", "eventual"]
        },
        "staleness_budget": {
          "type": "string"
        },
        "cacheability": {
          "type": "string",
          "enum": ["cacheable", "private-cacheable", "not-cacheable"]
        }
      },
      "additionalProperties": false
    },
    "cross_service_read": {
      "type": "object",
      "required": ["target_service", "entity", "read_mode"],
      "properties": {
        "target_service": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "entity": {
          "type": "string"
        },
        "read_mode": {
          "type": "string",
          "enum": ["query-api", "projection", "forbidden"]
        },
        "consistency": {
          "type": "string",
          "enum": ["strong", "read-your-write", "monotonic-read", "bounded-staleness", "eventual"]
        },
        "staleness_budget": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "spec_completeness": {
      "type": "object",
      "required": ["ownership", "consistency", "idempotency", "partitioning", "failure_behavior"],
      "properties": {
        "ownership": {
          "type": "string",
          "enum": ["declared", "verified", "tested"]
        },
        "consistency": {
          "type": "string",
          "enum": ["draft", "declared", "verified"]
        },
        "idempotency": {
          "type": "string",
          "enum": ["declared", "verified"]
        },
        "partitioning": {
          "type": "string",
          "enum": ["declared", "deferred"]
        },
        "failure_behavior": {
          "type": "string",
          "enum": ["declared", "deferred"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
